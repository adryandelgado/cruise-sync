# Copy this file to .env.local and fill in real values.
# Vite exposes anything prefixed with VITE_ to the client bundle.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — Playwright authenticated smoke test (not sent to the client bundle)
# E2E_EMAIL=you@example.com
# E2E_PASSWORD=your-test-password

# Optional — GitHub Actions secrets for full E2E in CI:
# VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, E2E_EMAIL, E2E_PASSWORD
